{
  "name": "vamos-pos-backend",
  "version": "1.0.0",
  "description": "Vamos POS System backend",
  "main": "dist/server.js",
  "bin": "dist/server.js",
  "pkg": {
    "assets": [
      "dist/**/*",
      "public/**/*",
      "node_modules/**/*.node",
      "prisma/schema.prisma"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "bundle": "pkg . --output vamous-pos.exe",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --force-reset && ts-node src/database/seed-complete.ts",
    "seed": "ts-node src/database/seed.ts",
    "seed:all": "ts-node src/database/seed-complete.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/socket.io": "^3.0.1",
    "axios": "^1.14.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "qrcode-terminal": "^0.12.0",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "whatsapp-web.js": "^1.34.6",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/serialport": "^8.0.5",
    "nodemon": "^3.1.14",
    "pkg": "^5.8.1",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
