generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  password        String
  name            String
  role            Role           @default(KASIR)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  shifts          CashierShift[]
  paymentsHandled Payment[]      @relation("PaymentCashier")
  sessionsHandled Session[]      @relation("SessionCashier")
  syncStatus      SyncState      @default(PENDING)
}

model Venue {
  id                  String    @id @default(uuid())
  name                String
  address             String?
  openTime            String    @default("09:00")
  closeTime           String    @default("23:00")
  relayComPort        String    @default("COM3")
  printerPath         String    @default("USB001")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?
  blinkWarningMinutes Int       @default(5)
  servicePercent      Float     @default(5)
  taxPercent          Float     @default(11)
  isSyncEnabled       Boolean   @default(true)
  syncIntervalSeconds Int       @default(30)
  splashImageUrl      String?
  phone               String?   @default("6281244047610")
  waVerificationText  String?   @default("Halo Vamos Pool, saya ingin verifikasi akun member saya dengan ID:")
  isRelayEnabled      Boolean   @default(true)
  tables              Table[]
}

model Table {
  id                String            @id @default(uuid())
  venueId           String
  name              String
  type              String
  status            TableStatus       @default(AVAILABLE)
  relayChannel      Int
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  isKingTable       Boolean           @default(false)
  kingStatus        KingTable?
  sessions          Session[]
  venue             Venue             @relation(fields: [venueId], references: [id])
  tournamentMatches TournamentMatch[]
  waitlist          Waitlist[]
}

model PricingRule {
  id                String    @id @default(uuid())
  name              String
  tableType         String
  dayOfWeek         Int[]
  startTime         String
  endTime           String
  ratePerHour       Float
  memberRatePerHour Float?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
}

model Package {
  id          String    @id @default(uuid())
  name        String
  tableType   String
  duration    Int
  price       Float
  memberPrice Float?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  dayOfWeek   Int[]
  endTime     String?
  fnbItems    String?
  startTime   String?
  sessions    Session[]
}

model License {
  id          String    @id @default(uuid())
  licenseKey  String    @unique
  hardwareId  String?   @unique
  isActivated Boolean   @default(false)
  activatedAt DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model Member {
  id                          String                  @id @default(uuid())
  name                        String
  phone                       String                  @unique
  email                       String?                 @unique
  password                    String?
  photo                       String?
  loyaltyPoints               Int                     @default(0)
  tier                        String                  @default("BRONZE")
  totalPlayHours              Float                   @default(0)
  totalMatches                Int                     @default(0)
  totalWins                   Int                     @default(0)
  totalPrizeWon               Float                   @default(0)
  winRate                     Float                   @default(0)
  streakCount                 Int                     @default(0)
  streakLastPlay              DateTime?
  streakRewarded              Boolean                 @default(false)
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  deletedAt                   DateTime?
  handicap                    String                  @default("4")
  handicapLabel               String?                 @default("Entry Fragger")
  identityStatus              String                  @default("UNVERIFIED")
  isPhotoVerified             Boolean                 @default(false)
  isWaVerified                Boolean                 @default(false)
  photoVerifiedAt             DateTime?
  waVerifiedAt                DateTime?
  badges                      String[]                @default([])
  experience                  Int                     @default(0)
  isVerificationRewardClaimed Boolean                 @default(false)
  level                       Int                     @default(1)
  currentMonthPlayHours       Float                   @default(0)
  lastMonthPlayHours          Float                   @default(0)
  tierUpdatedAt               DateTime                @default(now())
  totalSpend                  Float                   @default(0)
  deviceId                    String?
  lastLoginAt                 DateTime?
  ratingConfidence            Int                     @default(0)
  skillRating                 Int                     @default(200)
  highestKingStreak           Int                     @default(0)
  syncStatus                  SyncState               @default(PENDING)
  expenses                    Expense[]
  kingTitles                  KingTable[]
  challengesSent              MatchChallenge[]        @relation("ChallengerRelation")
  challengesReceived          MatchChallenge[]        @relation("OpponentRelation")
  matches                     MatchMember[]
  pointLogs                   PointLog[]
  redemptions                 Redemption[]
  sessions                    Session[]
  tournamentParticipant       TournamentParticipant[]
  waitlist                    Waitlist[]
  rankHistory                 RankHistory[]

  @@index([syncStatus])
}

model Session {
  id              String           @id @default(uuid())
  tableId         String?
  status          SessionStatus    @default(ACTIVE)
  startTime       DateTime         @default(now())
  endTime         DateTime?
  durationOpts    Int?
  packageId       String?
  tableAmount     Float            @default(0)
  fnbAmount       Float            @default(0)
  totalAmount     Float            @default(0)
  memberId        String?
  customerName    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  paymentMethod   String?
  fnbIncluded     String?
  cashierId       String?
  serviceAmount   Float            @default(0)
  taxAmount       Float            @default(0)
  pausedAt        DateTime?
  totalPausedMs   Int              @default(0)
  billingType     String?
  syncStatus      SyncState        @default(PENDING)
  expenses        Expense[]
  matches         Match[]
  matchChallenges MatchChallenge[]
  orders          Order[]
  payments        Payment[]
  pointLogs       PointLog[]
  cashier         User?            @relation("SessionCashier", fields: [cashierId], references: [id])
  member          Member?          @relation(fields: [memberId], references: [id])
  package         Package?         @relation(fields: [packageId], references: [id])
  table           Table?           @relation(fields: [tableId], references: [id])

  @@index([status]) // getActiveSessions, getPendingSessions
  @@index([tableId]) // session per meja
  @@index([memberId]) // riwayat member
  @@index([status, durationOpts]) // checkExpiredSessions
  @@index([createdAt]) // laporan harian/bulanan
  @@index([syncStatus])
}

model Product {
  id           String         @id @default(uuid())
  name         String
  price        Float
  stock        Int            @default(0)
  category     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  orders       Order[]
  stockHistory StockHistory[]
}

model StockHistory {
  id            String   @id @default(uuid())
  productId     String
  quantity      Int
  type          String   @default("ADJUSTMENT")
  previousStock Int
  newStock      Int
  notes         String?
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id])
}

model Order {
  id         String    @id @default(uuid())
  sessionId  String
  productId  String
  quantity   Int
  price      Float
  total      Float
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  syncStatus SyncState @default(PENDING)
  product    Product   @relation(fields: [productId], references: [id])
  session    Session   @relation(fields: [sessionId], references: [id])

  @@index([sessionId]) // getActiveSessions bulk order fetch
  @@index([syncStatus])
}

model Payment {
  id         String        @id @default(uuid())
  sessionId  String?
  amount     Float
  discount   Float         @default(0)
  received   Float         @default(0)
  change     Float         @default(0)
  method     String
  status     String        @default("SUCCESS")
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?
  syncStatus SyncState     @default(PENDING)
  cashierId  String?
  shiftId    String?
  cashier    User?         @relation("PaymentCashier", fields: [cashierId], references: [id])
  session    Session?      @relation(fields: [sessionId], references: [id])
  shift      CashierShift? @relation(fields: [shiftId], references: [id])

  @@index([sessionId]) // laporan per sesi
  @@index([shiftId]) // laporan per shift kasir
  @@index([createdAt]) // laporan harian
  @@index([syncStatus])
}

model Match {
  id        String        @id @default(uuid())
  sessionId String
  winnerId  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  session   Session       @relation(fields: [sessionId], references: [id])
  members   MatchMember[]
}

model MatchMember {
  id       String @id @default(uuid())
  matchId  String
  memberId String
  match    Match  @relation(fields: [matchId], references: [id])
  member   Member @relation(fields: [memberId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String
  details   String?
  createdAt DateTime @default(now())

  @@index([createdAt]) // cleanup job (hapus log > 90 hari)
}

model Tournament {
  id              String                  @id @default(uuid())
  name            String
  description     String?
  entryFee        Float                   @default(0)
  prizePool       Float                   @default(0)
  prizeChampion   Float                   @default(0)
  prizeRunnerUp   Float                   @default(0)
  prizeSemiFinal  Float                   @default(0)
  maxPlayers      Int                     @default(32)
  status          TournamentStatus        @default(PENDING)
  eliminationType EliminationType         @default(SINGLE)
  transitionSize  Int                     @default(32)
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?
  championId      String?
  format          String?                 @default("8-Ball")
  venue           String?
  rules           String?
  matches         TournamentMatch[]
  participants    TournamentParticipant[]
}

model TournamentParticipant {
  id            String            @id @default(uuid())
  tournamentId  String
  memberId      String?
  name          String?
  handicap      String?
  paymentStatus String            @default("UNPAID")
  registeredAt  DateTime          @default(now())
  paymentNotes  String?
  matchPlayer1  TournamentMatch[] @relation("Player1")
  matchPlayer2  TournamentMatch[] @relation("Player2")
  matchWinner   TournamentMatch[] @relation("Winner")
  member        Member?           @relation(fields: [memberId], references: [id])
  tournament    Tournament        @relation(fields: [tournamentId], references: [id])
}

model TournamentMatch {
  id           String                 @id @default(uuid())
  tournamentId String
  round        Int
  matchNumber  Int
  bracket      BracketType            @default(WINNERS)
  player1Id    String?
  player2Id    String?
  winnerId     String?
  score1       Int                    @default(0)
  score2       Int                    @default(0)
  status       String                 @default("PENDING")
  tableId      String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  player1      TournamentParticipant? @relation("Player1", fields: [player1Id], references: [id])
  player2      TournamentParticipant? @relation("Player2", fields: [player2Id], references: [id])
  table        Table?                 @relation(fields: [tableId], references: [id])
  tournament   Tournament             @relation(fields: [tournamentId], references: [id])
  winner       TournamentParticipant? @relation("Winner", fields: [winnerId], references: [id])
}

model Expense {
  id          String        @id @default(uuid())
  category    String
  amount      Float
  description String
  date        DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  isDebt      Boolean       @default(false)
  memberId    String?
  sessionId   String?
  shiftId     String?
  status      String        @default("PAID")
  syncStatus  SyncState     @default(PENDING)
  member      Member?       @relation(fields: [memberId], references: [id])
  session     Session?      @relation(fields: [sessionId], references: [id])
  shift       CashierShift? @relation(fields: [shiftId], references: [id])

  @@index([memberId, isDebt]) // piutang per member
  @@index([date]) // laporan harian
  @@index([syncStatus])
}

model Employee {
  id          String       @id @default(uuid())
  name        String
  position    String
  phone       String?
  email       String?
  salary      Float        @default(0)
  joinDate    DateTime     @default(now())
  status      String       @default("ACTIVE")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  attendances Attendance[]
}

model Attendance {
  id         String    @id @default(uuid())
  employeeId String
  date       DateTime  @default(now())
  checkIn    DateTime?
  checkOut   DateTime?
  status     String    @default("PRESENT")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee  @relation(fields: [employeeId], references: [id])
}

model Reward {
  id             String       @id @default(uuid())
  title          String
  description    String
  pointsRequired Int
  rewardType     RewardType   @default(DISCOUNT)
  value          Float        @default(0)
  stock          Int          @default(999)
  imageUrl       String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  category       String?
  isRestricted   Boolean      @default(false)
  restrictedDays Int[]        @default([])
  redemptions    Redemption[]
}

model Redemption {
  id         String   @id @default(uuid())
  memberId   String
  rewardId   String
  pointsUsed Int      @default(0)
  claimedAt  DateTime @default(now())
  status     String   @default("PENDING")
  notes      String?
  member     Member   @relation(fields: [memberId], references: [id])
  reward     Reward   @relation(fields: [rewardId], references: [id])
}

/// Granular log for every point event (earn / redeem / adjust)
model PointLog {
  id           String      @id @default(uuid())
  memberId     String
  type         PointTxType
  points       Int
  description  String
  sessionId    String?
  redemptionId String?
  createdAt    DateTime    @default(now())
  member       Member      @relation(fields: [memberId], references: [id])
  session      Session?    @relation(fields: [sessionId], references: [id])

  @@index([memberId]) // riwayat poin member
}

/// Global config store for loyalty settings (double-point toggle, etc.)
model LoyaltyConfig {
  id                 String    @id @default("global")
  doublePointEnabled Boolean   @default(false)
  doublePointExpiry  DateTime?
  pointPerRupiah     Float     @default(1)
  streakThreshold    Int       @default(5)
  streakWindowDays   Int       @default(30)
  streakBonusPoints  Int       @default(100)
  isPointsEnabled    Boolean   @default(true)
  updatedAt          DateTime  @updatedAt
  updatedBy          String?
  pointsExpiryDays   Int       @default(180)

  // Tier Thresholds (Experience/XP)
  silverThreshold   Int @default(1000)
  goldThreshold     Int @default(2500)
  platinumThreshold Int @default(5000)

  // Tier Multipliers (Earn Rates)
  silverMultiplier   Float @default(1.1)
  goldMultiplier     Float @default(1.25)
  platinumMultiplier Float @default(1.5)
}

model Waitlist {
  id              String    @id @default(uuid())
  customerName    String
  phone           String?
  partySize       Int       @default(1)
  tableType       String?
  status          String    @default("WAITING")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  reservedTime    DateTime?
  tableId         String?
  memberId        String?
  durationMinutes Int       @default(60)
  packageId       String?
  pointsCost      Int?
  price           Float     @default(0)
  syncStatus      SyncState @default(PENDING)
  member          Member?   @relation(fields: [memberId], references: [id])
  table           Table?    @relation(fields: [tableId], references: [id])

  @@index([syncStatus])
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  imageUrl  String?
  targetUrl String?
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KingTable {
  tableId      String   @id
  kingMemberId String
  streak       Int      @default(0)
  sinceMatchId String?
  updatedAt    DateTime @updatedAt
  king         Member   @relation(fields: [kingMemberId], references: [id])
  table        Table    @relation(fields: [tableId], references: [id])
}

model MatchChallenge {
  id              String   @id @default(uuid())
  challengerId    String
  opponentId      String?
  pointsStake     Int      @default(50)
  status          String   @default("PENDING")
  winnerId        String?
  score1          Int      @default(0)
  score2          Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isFightForTable Boolean  @default(false)
  sessionId       String?
  note            String?
  challenger      Member   @relation("ChallengerRelation", fields: [challengerId], references: [id])
  opponent        Member?  @relation("OpponentRelation", fields: [opponentId], references: [id])
  session         Session? @relation(fields: [sessionId], references: [id])
}

model DiscountCategory {
  id          String    @id @default(uuid())
  name        String
  type        String    @default("PERCENTAGE")
  value       Float
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model CashierShift {
  id               String    @id @default(uuid())
  userId           String
  startTime        DateTime  @default(now())
  endTime          DateTime?
  startingCash     Float     @default(0)
  endingCashActual Float?
  expectedCash     Float?
  expectedQris     Float?
  expectedCard     Float?
  notes            String?
  status           String    @default("OPEN")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  syncStatus       SyncState @default(PENDING)
  user             User      @relation(fields: [userId], references: [id])
  expenses         Expense[]
  payments         Payment[]

  @@index([syncStatus])
}

/// Template pesan WhatsApp yang bisa diedit via admin
model WaTemplate {
  id        String   @id
  name      String
  body      String
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
  updatedBy String?
  imageUrl  String?
}

enum EliminationType {
  SINGLE
  DOUBLE
}

enum BracketType {
  WINNERS
  LOSERS
}

enum Role {
  ADMIN
  MANAGER
  KASIR
  OWNER
}

enum SessionStatus {
  ACTIVE
  FINISHED
  PENDING
  PAID
  CANCELLED
}

enum TournamentStatus {
  PENDING
  ONGOING
  COMPLETED
  CANCELLED
}

enum TableStatus {
  AVAILABLE
  PLAYING
  MAINTENANCE
  CLEANING
}

enum RewardType {
  DISCOUNT
  FREE_GAME
  FNB_VOUCHER
  VIP_ACCESS
}

enum PointTxType {
  EARN_GAME
  EARN_FNB
  EARN_TOURNAMENT
  EARN_STREAK
  EARN_BONUS
  REDEEM
  ADJUSTMENT
  EXPIRY
}

enum SyncState {
  PENDING
  SYNCED
  FAILED
}

model RankHistory {
  id           String   @id @default(uuid())
  memberId     String
  oldHandicap  String?
  newHandicap  String
  oldRating    Int?
  newRating    Int
  reason       String? // E.g., "MATCH_RESULT", "ADMIN_VERIFIED", "MONTHLY_RESET"
  notes        String? // Optional notes about the change
  matchId      String? // Reference to the match that caused the change
  createdAt    DateTime @default(now())
  member       Member   @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@index([createdAt])
}
